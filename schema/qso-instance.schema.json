{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aevespers2/QuantumStateObjects/blob/main/schema/qso-instance.schema.json",
  "title": "Versioned Quantum State Object Instance",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "instance_id",
    "declared_name",
    "primary_name",
    "secondary_name",
    "lineage_suffix",
    "version",
    "genome",
    "identity_declaration",
    "development",
    "sprite_review",
    "status"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "instance_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{2,127}$"},
    "declared_name": {"type": "string", "pattern": "^[A-Z][A-Za-z0-9]*-[A-Z][A-Za-z0-9]*-Vespers$"},
    "primary_name": {"enum": ["Atlas", "Nova", "Orion", "Lyra"]},
    "secondary_name": {"type": "string", "pattern": "^[A-Z][A-Za-z0-9]{1,31}$"},
    "lineage_suffix": {"const": "Vespers"},
    "version": {"type": "string", "pattern": "^0\\.[0-9]+\\.[0-9]+$"},
    "genome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "path", "schema_version"],
      "properties": {
        "repository": {"const": "aevespers2/QSO-GENOMES"},
        "path": {"type": "string", "pattern": "^genomes/(atlas|nova|orion|lyra)\\.json$"},
        "schema_version": {"const": 1},
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "Optional until an upstream genome is accepted; required by local genome resolution."
        }
      }
    },
    "identity_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["secondary_name_basis", "secondary_focus", "chosen_at_freeze_point", "human_review_required"],
      "properties": {
        "secondary_name_basis": {"enum": ["declared_intent", "secondary_focus", "demonstrated_specialization"]},
        "secondary_focus": {"type": "string", "minLength": 3, "maxLength": 300},
        "chosen_at_freeze_point": {"const": true},
        "human_review_required": {"const": true}
      }
    },
    "development": {
      "type": "object",
      "additionalProperties": false,
      "required": ["interpretation_enabled", "self_reflection_enabled", "self_edit_mode", "immutable_fields_locked", "proposal_log", "max_proposals_per_run"],
      "properties": {
        "interpretation_enabled": {"const": true},
        "self_reflection_enabled": {"const": true},
        "self_edit_mode": {"const": "proposal_only"},
        "immutable_fields_locked": {"const": true},
        "proposal_log": {"type": "string", "pattern": "^proposals/[a-z0-9-]+\\.jsonl$"},
        "max_proposals_per_run": {"type": "integer", "minimum": 1, "maximum": 20}
      }
    },
    "sprite_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "sprite", "activation_rule"],
      "properties": {
        "required": {"const": true},
        "sprite": {"const": "aequitas"},
        "activation_rule": {"const": "pending_until_sprite_and_human_review"}
      }
    },
    "status": {"enum": ["draft", "pending_review", "active", "frozen", "retired"]}
  }
}
